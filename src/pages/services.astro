  <script>
    (function () {
      const sections = Array.from(document.querySelectorAll('[data-tab-section]'));
      const tabs = Array.from(document.querySelectorAll('[data-tab]'));
      if (!sections.length || !tabs.length) return;

      const GOLD = '#d7b09a';
      const MUTED = '#9a8f85';

      function activate(tabId) {
        // Hide all sections
        sections.forEach(s => { (s as HTMLElement).style.display = 'none'; });
        // Show target
        const target = document.getElementById(tabId);
        if (target) { (target as HTMLElement).style.display = 'block'; }
        // Update tab visual state
        tabs.forEach(t => {
          const el = t as HTMLElement;
          const isActive = el.getAttribute('data-tab') === tabId;
          el.style.color = isActive ? GOLD : '';
          el.style.borderBottom = isActive ? `2px solid ${GOLD}` : '2px solid transparent';
        });
        // Persist to URL without scrolling
        history.replaceState(null, '', '#' + tabId);
      }

      // Wire up click handlers
      tabs.forEach(t => {
        t.addEventListener('click', () => {
          const id = (t as HTMLElement).getAttribute('data-tab');
          if (id) activate(id);
        });
      });

      // On load: honour URL hash, else default to massage
      const hash = location.hash.replace('#', '');
      const valid = sections.some(s => s.id === hash);
      activate(valid ? hash : 'massage');
    })();
  </script>
